LOG_LEVEL=DEBUG

# --- logger (edit per inverter) ---
DEYE_LOGGER_IP_ADDRESS=192.168.178.100
DEYE_LOGGER_PORT=8899
DEYE_LOGGER_SERIAL_NUMBER=4145330384
DEYE_LOGGER_PROTOCOL=solarman_v5
DEYE_METRIC_GROUPS=micro
DEYE_DATA_READ_INTERVAL=30
DEYE_PUBLISH_ON_CHANGE_MAX_INTERVAL=300
# DEYE_LOGGER_MAX_REG_RANGE_LENGTH=16

# --- MQTT broker (Pi host) ---
MQTT_HOST=192.168.178.52
MQTT_PORT=1883
MQTT_USERNAME=solar
MQTT_PASSWORD=CHANGE_ME
MQTT_TOPIC_PREFIX=solar/home/sun300g3

