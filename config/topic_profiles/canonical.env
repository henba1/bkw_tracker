# Canonical MQTT topic suffixes (vendor-neutral MQTT contract)
MQTT_TOPIC_AC_POWER=ac/power_w
MQTT_TOPIC_PV_POWER=pv/power_w
MQTT_TOPIC_ENERGY_TODAY=energy/today_kwh
MQTT_TOPIC_ENERGY_TOTAL=energy/total_kwh
MQTT_TOPIC_GRID_VOLTAGE=ac/voltage_v
MQTT_TOPIC_GRID_FREQUENCY=ac/frequency_hz
MQTT_TOPIC_TEMPERATURE=device/temperature_c
MQTT_TOPIC_BRIDGE_STATUS=_meta/availability
MQTT_TOPIC_DEVICE_STATUS=_meta/availability
