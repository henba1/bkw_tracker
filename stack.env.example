# bkw_tracker stack configuration — copy to stack.env and edit.
# All services read derived config rendered from this file at startup.
#   cp stack.env.example stack.env

# --- host / site topology ---
# HOST_IP=auto resolves the default-route IPv4 at render time (recommended on the Pi).
HOST_IP=auto
SITE_ID=home
INVERTER_ID=sun300g3

# --- Deye logger (vendor-specific — edit when swapping hardware) ---
LOGGER_IP=
LOGGER_SERIAL=4145330384
LOGGER_SERIAL_FALLBACK=2208093531
# SUN300G3 WIFI-G3: at/48899 (solarman_v5 unsupported in deye-inverter-mqtt; tcp on 8899 returns AT response)
LOGGER_PROTOCOL=at
LOGGER_PORT=48899

# --- MQTT broker (runs on HOST_IP) ---
MQTT_USER=solar
MQTT_PASSWORD=
MQTT_PORT=1883
# Leave empty to derive: solar/<SITE_ID>/<INVERTER_ID>
MQTT_TOPIC_PREFIX=

# --- acquisition & MQTT contract ---
# deye = bundled deye-inverter-mqtt adapter (default, tested on Deye SUN300G3)
# external = your inverter/solarbank already publishes to Mosquitto (no deye-bridge)
ACQUISITION_ADAPTER=deye
# Topic suffix profile — must match what publishes under MQTT_TOPIC_PREFIX:
#   deye       = deye-inverter-mqtt native suffixes (ac/active_power, …)
#   canonical  = vendor-neutral contract (ac/power_w, …) — see config/topic_profiles/canonical.env
MQTT_TOPIC_PROFILE=deye

# --- deye-bridge tuning (ACQUISITION_ADAPTER=deye only) ---
LOG_LEVEL=DEBUG
DEYE_METRIC_GROUPS=micro
DEYE_DATA_READ_INTERVAL=30
DEYE_PUBLISH_ON_CHANGE_MAX_INTERVAL=300
# DEYE_LOGGER_MAX_REG_RANGE_LENGTH=16

# --- logger resilience (ACQUISITION_ADAPTER=deye only) ---
# When deye-bridge publishes logger_status=offline, logger-resilience runs spaced
# UDP wakeup probes (like probe_logger) and restarts deye-bridge on first success
# so the next full Modbus read happens while the WiFi module is responsive.
LOGGER_RESILIENCE_ENABLED=true
LOGGER_RESILIENCE_DAYLIGHT_ONLY=true
# When true, skip recovery between 00:00 and 04:45 local time (no PV at this site).
LOGGER_OFFLINE_THRESHOLD=1
LOGGER_WAKEUP_ATTEMPTS=5
LOGGER_WAKEUP_INTERVAL_SEC=8
LOGGER_PROBE_TIMEOUT_SEC=2
LOGGER_RECOVERY_RESTART=true
LOGGER_RECOVERY_COOLDOWN_SEC=90
LOGGER_RESILIENCE_MQTT_WAIT_SEC=120
DEYE_BRIDGE_CONTAINER=deye-bridge

# --- healthcheck (scripts/healthcheck.sh) ---
HEALTHCHECK_STALE_SECONDS=600
HEALTHCHECK_LATITUDE=52.0
HEALTHCHECK_LONGITUDE=13.0

# --- Home Assistant (Phase 3 & 4) ---
# Existing container on this Pi: docker ps → homeassistant
HA_CONTAINER=homeassistant
# Auto-detected from container /config mount; override if needed:
# HA_CONFIG=/opt/homeassistant/homeassistant
HA_CONFIG=
# homeassistant uses host network → Mosquitto on same Pi is localhost
MQTT_BROKER_HOST=127.0.0.1
HA_EXPIRE_AFTER=120

# --- HA package metadata (rendered into homeassistant/packages/solar.yaml) ---
HA_INVERTER_MANUFACTURER=Deye
HA_INVERTER_MODEL=SUN300G3-EU-230
# Optional override for MQTT entity_id slug (default: deye_sun300g3_eu_230)
# HA_ENTITY_SLUG=deye_sun300g3_eu_230
